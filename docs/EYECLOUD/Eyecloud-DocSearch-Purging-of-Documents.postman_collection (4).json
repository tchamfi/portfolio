							"script": {
								"exec": [
									"var json = JSON.parse(responseBody);\r",
									"var moment = require('moment');\r",
									" pm.globals.set(\"ecid1\", json[\"0\"]);\r",
									" pm.globals.set(\"ecid2\", json[\"1\"]);\r",
									" pm.globals.set(\"ecid3\", json[\"2\"]);\r",
									" pm.globals.set(\"current_date\", moment().format(\"yyyy/MM/DD\"));\r",
									" pm.globals.set(\"from_date\", moment().format(\"yyyy/MM/DD\")+\" 00:00:00\");\r",
									" pm.globals.set(\"to_date\", moment().format(\"yyyy/MM/DD\")+\" 23:59:59\");\r",
									" console.log(\"ecid1 -> \"+pm.globals.get(\"ecid1\")); \r",
									" console.log(\"ecid2 -> \"+pm.globals.get(\"ecid2\")); \r",
									" console.log(\"ecid3 -> \"+pm.globals.get(\"ecid3\")); \r",
									" console.log(\"from_date -> \"+pm.globals.get(\"from_date\")); \r",
									" console.log(\"to_date -> \"+pm.globals.get(\"to_date\")); \r",
									"\r",
									"if (responseCode.code === 201)\r",
									"{\r",
									"var jsonData = JSON.parse(responseBody);\r",
									"tests[\"Status Code is 201\"] = responseCode.code === 201;\r",
									"\r",
									"tests[\"Response time is acceptable if<5s\"] = responseTime < 5000;\r",
									"};"
								],
								"type": "text/javascript",
								"packages": {}
							}
